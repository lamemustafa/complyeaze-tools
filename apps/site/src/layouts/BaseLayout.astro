---
import "../styles/global.css";
import "../styles/tool.css";
import { publicSiteUrl } from "../lib/public-url";

const {
  title = "ComplyEaze Tools",
  description = "Private browser tools that turn messy Indian compliance records into review-ready action packs.",
} = Astro.props;

const repositoryUrl = "https://github.com/lamemustafa/complyeaze-tools";
const licenseUrl = `${repositoryUrl}/blob/main/LICENSE`;
const releaseGatesUrl = `${repositoryUrl}/blob/main/docs/release-gates.md`;
const provenanceUrl = `${repositoryUrl}/actions/workflows/publish-image.yml`;
const canonicalUrl = publicSiteUrl(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={publicSiteUrl("/")} aria-label="ComplyEaze Tools home">
        <span class="brand-mark">CE</span>
        <span>ComplyEaze Tools</span>
      </a>
      <nav aria-label="Primary">
        <a href={publicSiteUrl("/source")}>Sources</a>
        <a href={publicSiteUrl("/privacy")}>Privacy</a>
        <a href={publicSiteUrl("/security")}>Security</a>
        <a href={publicSiteUrl("/status")}>Status</a>
        <a href={repositoryUrl}>GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <nav class="footer-links" aria-label="Open-source trust links">
        <a href={repositoryUrl}>Source code</a>
        <a href={licenseUrl}>Apache-2.0 license</a>
        <a href={releaseGatesUrl}>Reproducible build gates</a>
        <a href={provenanceUrl}>SBOM and provenance workflow</a>
      </nav>
      <p>
        Files are processed in your browser. No account or file upload required.
      </p>
      <p>
        Not affiliated with GSTN, CBIC, the Income Tax Department, MCA, MSME
        Samadhaan, or the Government of India.
      </p>
    </footer>
  </body>
</html>
