---
import "../styles/global.css";
import "../styles/sections.css";
import "../styles/tool.css";
import { publicSiteUrl } from "../lib/public-url";

const {
  title = "ComplyEaze Tools",
  description = "Private browser tools that turn messy Indian compliance records into review-ready action packs.",
} = Astro.props;

const repositoryUrl = "https://github.com/lamemustafa/complyeaze-tools";
const licenseUrl = `${repositoryUrl}/blob/main/LICENSE`;
const releaseGatesUrl = `${repositoryUrl}/blob/main/docs/release-gates.md`;
const publishWorkflowUrl = `${repositoryUrl}/actions/workflows/publish-image.yml`;
const canonicalUrl = publicSiteUrl(Astro.url.pathname);
const siteName = "ComplyEaze Tools";
const siteDescription =
  "Private browser tools that turn messy Indian compliance records into review-ready action packs.";
const socialImageUrl = publicSiteUrl("/social-card.png");
const faviconUrl = "/favicon.svg";
const manifestUrl = "/site.webmanifest";
const siteSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: publicSiteUrl("/"),
    description: siteDescription,
    publisher: {
      "@type": "Organization",
      name: "ComplyEaze",
      url: "https://complyeaze.com/",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "ComplyEaze Tools",
    codeRepository: repositoryUrl,
    license: "https://www.apache.org/licenses/LICENSE-2.0",
    programmingLanguage: ["TypeScript", "Astro", "React"],
    runtimePlatform: "Web browser",
    description: siteDescription,
    url: publicSiteUrl("/"),
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0c6b58" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ComplyEaze Tools browser-local compliance tools" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />
    <link rel="manifest" href={manifestUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={publicSiteUrl("/")} aria-label="ComplyEaze Tools home">
        <span class="brand-mark">CE</span>
        <span>ComplyEaze Tools</span>
      </a>
      <nav aria-label="Primary">
        <a href={publicSiteUrl("/source")}>Sources</a>
        <a href={publicSiteUrl("/privacy")}>Privacy</a>
        <a href={publicSiteUrl("/security")}>Security</a>
        <a href={publicSiteUrl("/status")}>Status</a>
        <a href={repositoryUrl}>GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <nav class="footer-links" aria-label="Open-source trust links">
        <a href={repositoryUrl}>Source code</a>
        <a href={licenseUrl}>Apache-2.0 license</a>
        <a href={releaseGatesUrl}>Reproducible build gates</a>
        <a href={publishWorkflowUrl}>Image scan and digest workflow</a>
      </nav>
      <p>
        Files are processed in your browser. No account or file upload required.
      </p>
      <p>
        Not affiliated with GSTN, CBIC, the Income Tax Department, MCA, MSME
        Samadhaan, or the Government of India.
      </p>
    </footer>
  </body>
</html>
