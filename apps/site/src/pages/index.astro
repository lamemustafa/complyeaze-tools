---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLaunchTools } from "../lib/tools";
import { publicSiteUrl } from "../lib/public-url";

const tools = getLaunchTools();
const axalUrl = "https://complyeaze.com/axal";
const sanchikaUrl = publicSiteUrl("/sanchika");
const clusters = [
  {
    title: "Reconciliation and vendor follow-up",
    description:
      "Triage GSTR-2B mismatches and turn supplier gaps into review-ready follow-up drafts.",
    slugs: [
      "/gstr-2b-purchase-reconciliation-triage",
      "/gstr-2b-missing-invoice-vendor-follow-up",
    ],
  },
  {
    title: "Evidence and review copy",
    description:
      "Prepare portal issue timelines, privacy-conscious review copies, and professional handoff notes.",
    slugs: ["/gst-portal-issue-evidence-memo", "/privacy/review-copy-builder"],
  },
  {
    title: "Tax and payables review",
    description:
      "Create first-pass mismatch and payables-age review drafts before professional verification.",
    slugs: ["/ais-form-26as-mismatch-checker", "/msme-45-day-payment-due-date-calculator"],
  },
  {
    title: "GST filing safety",
    description:
      "Check liability gaps and pre-lock figures before GSTR-1/GSTR-3B filing closes the correction window.",
    slugs: [
      "/gstr1-gstr3b-liability-mismatch-pre-checker",
      "/gstr3b-outward-liability-prelock-gap-checker",
    ],
  },
  {
    title: "Income tax and TDS transition",
    description:
      "Translate old TDS sections into the Income-tax Act, 2025 and format capital-gains rows for Schedule 112A.",
    slugs: [
      "/income-tax-act-2025-tds-section-translator",
      "/schedule-112a-capital-gains-csv-builder",
    ],
  },
  {
    title: "Payroll and sector-specific compliance",
    description:
      "Recalculate gratuity under the new wage definition and work through a MahaRERA withdrawal ceiling.",
    slugs: [
      "/labour-code-gratuity-wage-recalculator",
      "/maharera-form-3-withdrawal-worksheet",
    ],
  },
].map((cluster) => ({
  ...cluster,
  tools: cluster.slugs
    .map((slug) => tools.find((tool) => tool.slug === slug))
    .filter(Boolean),
}));
---

<BaseLayout
  title="Browser-Local Indian Compliance Draft Tools | ComplyEaze Tools"
  description="Browser-local Indian compliance draft tools for reconciliation triage, payables review, vendor follow-ups, evidence memos, and review copies."
>
  <section class="hero">
    <div>
      <p class="domain-line">tools.complyeaze.com</p>
      <h1>Browser-local draft tools for Indian compliance work.</h1>
      <p class="lede">
        Turn messy records into first-pass review drafts: mismatch briefs,
        payables-age review sheets, vendor follow-ups, evidence memos, and
        review copies.
      </p>
      <div class="trust-strip">
        <span>Files processed in your browser</span>
        <span>No account required</span>
        <span>No file upload required</span>
        <span>Drafts for professional review</span>
      </div>
    </div>
    <aside class="source-card">
      <h2>Local-first posture</h2>
      <p>
        These tools create working artifacts from files or rows you provide.
        Axal remains the place for saved mappings, clients, documents, tasks,
        audit trails, and recurring workflows.
      </p>
    </aside>
  </section>

  <section class="tool-list" aria-label="ComplyEaze Tools">
    {tools.map((tool) => (
      <a class="tool-card" href={publicSiteUrl(tool.slug)}>
        <h2>{tool.h1}</h2>
        <p>{tool.metaDescription}</p>
        <span class="tool-meta">{tool.outputArtifacts.join(" / ")}</span>
      </a>
    ))}
  </section>

  <section class="workflow-section" aria-labelledby="workflow-heading">
    <div class="section-heading">
      <p class="domain-line">Workflows</p>
      <h2 id="workflow-heading">Choose by the work on your desk.</h2>
      <p>
        Each tool stays focused on one browser-local artifact. Axal is the path
        when the work needs clients, saved mappings, documents, tasks, and audit
        trails.
      </p>
    </div>
    <div class="workflow-grid">
      {clusters.map((cluster) => (
        <article class="workflow-panel">
          <h3>{cluster.title}</h3>
          <p>{cluster.description}</p>
          <ul>
            {cluster.tools.map((tool) => (
              <li>
                <a href={publicSiteUrl(tool.slug)}>{tool.h1}</a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="upgrade-band" aria-label="Sanchika design-system docs">
    <div>
      <h2>Need the shared UI package boundary?</h2>
      <p>
        Sanchika documents the tokens, primitives, workflow patterns, gallery,
        adoption order, and verification checks behind shared compliance UI.
      </p>
    </div>
    <a class="text-button" href={sanchikaUrl}>Open Sanchika docs</a>
  </section>

  <section class="upgrade-band" aria-label="Axal upgrade path">
    <div>
      <h2>Need saved mappings, evidence trails, and recurring workflows?</h2>
      <p>
        Use these tools for one-off drafts. Use Axal when the same work needs
        clients, documents, assignments, credential-safe workflows, and review
        history.
      </p>
    </div>
    <a class="text-button" href={axalUrl}>Open Axal</a>
  </section>
</BaseLayout>
