---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLaunchTools } from "../lib/tools";
import { publicSiteUrl } from "../lib/public-url";

const tools = getLaunchTools();
const freshnessIssueUrl =
  "https://github.com/lamemustafa/complyeaze-tools/issues/new?template=source_freshness.yml";
---

<BaseLayout
  title="Sources | ComplyEaze Tools"
  description="Official source register for ComplyEaze Tools, including source review dates, refresh windows, unsupported cases, and stale-source reporting."
>
  <section class="hero">
    <div>
      <h1>Source register.</h1>
      <p class="lede">
        Each tool renders source freshness, unsupported cases, and review-only
        boundaries. Official sources come first; news and community links are
        demand signals only.
      </p>
    </div>
  </section>
  <section class="detail-grid">
    {tools.map((tool) => (
      <article>
        <h2><a href={publicSiteUrl(tool.slug)}>{tool.h1}</a></h2>
        <p>
          Refresh policy: each source is reviewed again within its listed
          stale-after window. Report stale or changed sources through the public
          source freshness issue form using synthetic context only.
        </p>
        <ul>
          {tool.officialSources.map((source) => (
            <li>
              <a href={source.url}>{source.publisher}: {source.title}</a>
              {" "}reviewed {source.lastReviewedAt}; refresh after{" "}
              {source.staleAfterDays} days; used for {source.usedFor.join(", ")}
            </li>
          ))}
        </ul>
        <p>
          <a href={publicSiteUrl(tool.slug)}>Open this tool</a>
          {" "}or{" "}
          <a href={freshnessIssueUrl}>Report a stale source for this tool</a>
        </p>
      </article>
    ))}
  </section>
</BaseLayout>
