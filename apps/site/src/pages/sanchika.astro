---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/sanchika.css";

const repositoryUrl = "https://github.com/lamemustafa/sanchika";
const liveGalleryUrl = "https://sanchika.complyeaze.com";
const axalUrl = "https://axal.complyeaze.com";

const localPath = [
  {
    title: "Source",
    body: "The Sanchika gallery and source repository show the interface contract behind this page. They are public material to inspect, not a claim about a visitor's files or work.",
  },
  {
    title: "Draft",
    body: "Tools can shape a browser-local working artifact. It does not turn a draft into a filing position, authority decision, or stored client record.",
  },
  {
    title: "Export",
    body: "A clear label helps a practitioner choose what leaves the browser. A saved trail, assignment, or recurring workflow belongs to Axal.",
  },
];
---

<BaseLayout
  title="Local work has a boundary | ComplyEaze Tools"
  description="A public Sanchika proof route for browser-local ComplyEaze Tools: source-visible, explicit about drafts, and clear about what is not stored or decided."
>
  <section class="tools-proof" aria-labelledby="sanchika-heading">
    <div class="proof-heading">
      <p class="proof-meta"><strong>ComplyEaze Tools</strong> <span aria-hidden="true">/</span> Sanchika proof</p>
      <h1 id="sanchika-heading">Know what local work carries—and what it does not.</h1>
      <p class="proof-lede">
        This is a public reading surface for people who need the browser-local
        boundary before they need a component catalogue.
      </p>
    </div>

    <aside class="boundary-signal" aria-labelledby="boundary-signal-heading">
      <p class="signal-kicker">Visible before any handoff</p>
      <h2 id="boundary-signal-heading">Files are processed in your browser. No account or file upload required.</h2>
      <p>
        This page explains a public interface boundary. It does not promise an
        automated compliance judgment, a saved client record, or a portal result.
      </p>
      <a href="/privacy/">Read the privacy boundary</a>
    </aside>

    <nav class="proof-actions" aria-label="Sanchika proof links">
      <a class="proof-action primary" href={liveGalleryUrl}>Open Sanchika gallery</a>
      <a class="proof-action" href={repositoryUrl}>Review source</a>
    </nav>
  </section>

  <section class="local-path" aria-labelledby="local-path-heading">
    <div class="path-introduction">
      <p>How this route should be read</p>
      <h2 id="local-path-heading">A local artifact is useful precisely because its limits stay visible.</h2>
    </div>

    <ol class="path-list">
      {localPath.map((entry) => (
        <li>
          <h3>{entry.title}</h3>
          <p>{entry.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="proof-ledger" aria-labelledby="ledger-heading">
    <div>
      <p class="ledger-mark">Public proof, not a product workspace</p>
      <h2 id="ledger-heading">The contract can be inspected without asking anyone to trust a hidden system.</h2>
    </div>
    <dl>
      <div>
        <dt>This route is</dt>
        <dd>A static explanation of how the Sanchika contract helps a public Tools surface communicate source, draft state, and export boundaries.</dd>
      </div>
      <div>
        <dt>This route is not</dt>
        <dd>A filing result, a compliance conclusion, a client vault, an audit trail, or an account area.</dd>
      </div>
      <div>
        <dt>When work persists</dt>
        <dd>Use Axal for a saved workspace, collaboration, assignments, and recurring operating flow.</dd>
      </div>
    </dl>
  </section>

  <section class="proof-close" aria-labelledby="proof-close-heading">
    <div>
      <h2 id="proof-close-heading">Inspect the contract. Keep custody explicit.</h2>
      <p>
        The gallery shows the current interface evidence. The repository makes
        the underlying design-system work reviewable.
      </p>
    </div>
    <nav aria-label="Next proof routes">
      <a class="proof-action primary" href={liveGalleryUrl}>Open gallery</a>
      <a class="proof-action" href={repositoryUrl}>Sanchika source</a>
      <a class="proof-action" href={axalUrl}>Go to Axal</a>
    </nav>
  </section>
</BaseLayout>
