---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/sanchika.css";

const repositoryUrl = "https://github.com/lamemustafa/sanchika";
const liveGalleryUrl = "https://sanchika.complyeaze.com";
const familyStoryUrl = "https://complyeaze.com";
const axalUrl = "https://axal.complyeaze.com";
const packUrl = "https://pack.complyeaze.com";

const proofChain = [
  {
    code: "trust",
    title: "TrustBrief",
    body: "Names the claim, custody boundary, non-goals, and gates before a pattern is treated as reusable.",
  },
  {
    code: "shape",
    title: "DesignBrief",
    body: "Defines the first viewport, story pressure, responsive constraints, and expected states.",
  },
  {
    code: "paint",
    title: "Browser evidence",
    body: "Uses rendered desktop and mobile evidence to prove the surface actually paints as designed.",
  },
  {
    code: "adopt",
    title: "Adoption decision",
    body: "Records which product consumed the contract and what still needs proof before wider use.",
  },
];

const packageContracts = [
  ["tokens", "Portable variables for color, type, spacing, radius, and motion."],
  ["primitives", "Accessible React-first component contracts with platform-portable intent."],
  ["patterns", "Compliance workflow shapes for posture, evidence, source state, and action."],
  ["gallery", "Rendered examples that bind briefs, browser evidence, and adoption notes."],
];

const surfaces = [
  ["ComplyEaze", "family story", "Explains why Tools, Pack, Axal, and Sanchika exist together."],
  ["Axal", "workspace action", "Turns deadlines, source evidence, and review posture into operating flow."],
  ["Pack", "local proof", "Keeps GST return proof local and explicit about credential/file custody."],
  ["Tools", "public boundary", "Publishes static, browser-local surfaces without accounts, uploads, or telemetry."],
];

const verification = [
  "pnpm validate",
  "pnpm typecheck",
  "pnpm build",
  "pnpm artifact:check",
  "pnpm consumer:check",
  "pnpm publish:tarball-check",
];

const boundaries = [
  "Sanchika shapes interface contracts; it does not own clients, credentials, documents, filings, or audit trails.",
  "Tools stays static and browser-local: Files are processed in your browser. No account or file upload required.",
  "Consumers adopt through reviewed packages, tarballs, or copied design guidance, not nested runtime imports.",
  "Public claims must describe current evidence, not future component promises.",
];
---

<BaseLayout
  title="Sanchika Proof System | ComplyEaze Tools"
  description="A source-reviewable Sanchika design-system proof surface for ComplyEaze, Axal, Pack, and Tools adoption without accounts, uploads, telemetry, or persistence."
>
  <section class="sanchika-stage" aria-labelledby="sanchika-heading">
    <div class="stage-copy">
      <p class="domain-line">sanchika.complyeaze.com</p>
      <h1 id="sanchika-heading">Design that has to testify.</h1>
      <p class="stage-lede">
        Sanchika is the proof system for ComplyEaze interfaces: briefs, rendered
        evidence, package contracts, and adoption decisions held together so a
        beautiful compliance surface does not become a vague one.
      </p>
      <div class="stage-actions" aria-label="Sanchika primary links">
        <a class="sanchika-button" href={liveGalleryUrl}>Open Sanchika gallery</a>
        <a class="sanchika-link" href={repositoryUrl}>Review source</a>
        <a class="sanchika-link" href={familyStoryUrl}>Trace the family</a>
      </div>
    </div>

    <figure class="proof-instrument" aria-labelledby="instrument-title">
      <figcaption id="instrument-title">Sanchika proof instrument</figcaption>
      <div class="instrument-shell">
        <div class="instrument-axis axis-x" aria-hidden="true"></div>
        <div class="instrument-axis axis-y" aria-hidden="true"></div>
        <div class="instrument-core">
          <span>contract</span>
          <strong>reviewed before reused</strong>
        </div>
        {proofChain.map((proof, index) => (
          <article class={`instrument-node node-${index + 1}`}>
            <span>{proof.code}</span>
            <strong>{proof.title}</strong>
            <p>{proof.body}</p>
          </article>
        ))}
      </div>
    </figure>
  </section>

  <section class="sanchika-truth" aria-label="Current Sanchika truth">
    <p>
      Current truth: Sanchika is framework-agnostic in contract, React-first in
      adapter proof, and still adoption-gated. Its public surface should show
      evidence before it asks for belief.
    </p>
  </section>

  <section class="sanchika-narrative" aria-labelledby="narrative-heading">
    <div class="narrative-head">
      <h2 id="narrative-heading">A design system is not a costume.</h2>
      <p>
        ComplyEaze needs interfaces that feel different because their jobs are
        different. Sanchika carries a shared proof grammar without forcing the
        product family into one generic skin.
      </p>
    </div>
    <div class="surface-ledger" aria-label="Product surfaces shaped by Sanchika">
      {surfaces.map(([name, mode, body]) => (
        <article>
          <span>{mode}</span>
          <h3>{name}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="contract-section" aria-labelledby="contracts-heading">
    <div>
      <h2 id="contracts-heading">Packages are small promises.</h2>
      <p>
        Each layer has one job and one reason to change. That is what makes a
        design system portable without smuggling product state, tenant data, or
        filing behavior into consumers.
      </p>
    </div>
    <dl class="contract-list">
      {packageContracts.map(([name, body]) => (
        <div>
          <dt>@sanchika/{name}</dt>
          <dd>{body}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="verification-section" aria-labelledby="verification-heading">
    <div class="verification-panel">
      <h2 id="verification-heading">Beauty survives only if the gates agree.</h2>
      <p>
        Sanchika can be expressive, but adoption claims are earned through
        package checks, consumer checks, browser evidence, and publish-readiness
        gates.
      </p>
      <div class="command-strip" aria-label="Sanchika verification commands">
        {verification.map((command) => (
          <code>{command}</code>
        ))}
      </div>
    </div>
  </section>

  <section class="boundary-section" aria-labelledby="boundary-heading">
    <div>
      <h2 id="boundary-heading">The boundary is part of the artifact.</h2>
      <p>
        A page about craft still has to say what it will not do. That restraint
        is not a footnote; it is how compliance design remains trustworthy.
      </p>
    </div>
    <ul>
      {boundaries.map((boundary) => (
        <li>{boundary}</li>
      ))}
    </ul>
  </section>

  <section class="sanchika-close" aria-label="Sanchika related surfaces">
    <div>
      <h2>Inspect the loop where it lives.</h2>
      <p>
        The gallery shows the current evidence. The family surfaces show why the
        system has to adapt instead of merely repeat.
      </p>
    </div>
    <nav aria-label="Related public surfaces">
      <a class="sanchika-button" href={liveGalleryUrl}>Open gallery</a>
      <a class="sanchika-button secondary" href={axalUrl}>Axal</a>
      <a class="sanchika-button secondary" href={packUrl}>Pack</a>
      <a class="sanchika-button secondary" href={repositoryUrl}>Source</a>
    </nav>
  </section>
</BaseLayout>
